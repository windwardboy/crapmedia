# Supabase — Google OAuth (Settings → API in Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — admin dashboard (never NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated emails with admin access (import limits bypass + /admin)
ADMIN_EMAILS=you@example.com

# Optional YouTube import caps (defaults: 200/day, 100 per playlist import)
# YOUTUBE_DAILY_VIDEO_CAP=200
# YOUTUBE_SINGLE_IMPORT_CAP=100

# YouTube Data API v3 — server only (Vercel: player project, NOT NEXT_PUBLIC_)
YOUTUBE_API_KEY=
